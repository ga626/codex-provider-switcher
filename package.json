{
  "name": "codex-provider-switcher",
  "private": true,
  "version": "0.6.0-alpha",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "preview:start": "powershell -ExecutionPolicy Bypass -File scripts/start-preview.ps1",
    "preview:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-preview.ps1",
    "qa:smoke": "node scripts/qa-smoke.mjs",
    "qa:preview-smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/qa/run-preview-smoke.ps1",
    "qa:dev-desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/qa/start-dev-desktop.ps1",
    "qa:install-release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/qa/prepare-install-release-qa.ps1",
    "qa:updater-release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/qa/prepare-updater-release-qa.ps1",
    "qa:stable-install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/qa/stable-install.ps1",
    "qa:cutover-preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/qa/cutover-preflight.ps1",
    "backend:build": "cargo build --manifest-path src-tauri/Cargo.toml --bin local_backend --jobs 1",
    "backend:smoke": "node scripts/local-backend-smoke.mjs",
    "backend:functional-smoke": "node scripts/local-backend-functional-smoke.mjs",
    "backend:ui-smoke": "node scripts/local-backend-ui-smoke.mjs",
    "runtime-boundary:smoke": "node scripts/runtime-boundary-smoke.mjs",
    "tauri:desktop-boundary:smoke": "node scripts/tauri-desktop-boundary-smoke.mjs",
    "backend:dev": "cargo run --manifest-path src-tauri/Cargo.toml --bin local_backend --",
    "verify:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify/doctor-codex-provider-switcher.ps1 -PublicRelease",
    "release:readiness": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify/release-readiness.ps1",
    "release:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release/build-codex-provider-switcher-release.ps1",
    "release:verify-local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release/verify-local-release-package.ps1",
    "release:verify-upload-assets": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release/verify-release-upload-assets.ps1",
    "release:verify-remote": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release/verify-github-release-asset.ps1 -RemoteStructureOnly",
    "release:assets": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release/generate-installer-assets.ps1",
    "tauri:dev": "powershell -NoProfile -Command \"$env:CODEX_PROVIDER_SWITCHER_RELEASE_CHANNEL='development'; $env:CARGO_BUILD_JOBS='1'; npx tauri dev\"",
    "tauri:build": "npm run release:assets && tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.0",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1",
    "typescript": "~5.8.3",
    "vite": "^6.4.3"
  }
}
