{
  "name": "codex-provider-switcher",
  "private": true,
  "version": "0.1.0-alpha",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "preview:start": "powershell -ExecutionPolicy Bypass -File scripts/start-preview.ps1",
    "preview:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-preview.ps1",
    "qa:smoke": "node scripts/qa-smoke.mjs",
    "backend:build": "cargo build --manifest-path src-tauri/Cargo.toml --bin local_backend",
    "backend:smoke": "node scripts/local-backend-smoke.mjs",
    "backend:ui-smoke": "node scripts/local-backend-ui-smoke.mjs",
    "runtime-boundary:smoke": "node scripts/runtime-boundary-smoke.mjs",
    "backend:dev": "cargo run --manifest-path src-tauri/Cargo.toml --bin local_backend --",
    "verify:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify/doctor-codex-provider-switcher.ps1 -PublicRelease",
    "release:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release/build-codex-provider-switcher-release.ps1",
    "release:verify-local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release/verify-local-release-package.ps1",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1",
    "typescript": "~5.8.3",
    "vite": "^6.4.3"
  }
}
