{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the main Signalman AI window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://github.com/ga626/codex-provider-switcher/releases*"
        },
        {
          "url": "ms-windows-store://pdp/*"
        }
      ]
    },
    "process:allow-restart",
    "updater:default"
  ]
}
