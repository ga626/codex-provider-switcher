{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Signalman AI",
  "version": "0.8.0-alpha",
  "identifier": "studio.codex.provider-switcher",
  "mainBinaryName": "codex-provider-switcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Signalman AI",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; base-uri 'self'; form-action 'none'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY2NTlFMjg3RTM4QkYwQTEKUldTaDhJdmpoK0paOW9xZWZyKzc5eWxiVW1HWkRQbG5ab1orbDdFTVhvUXI3bW9ZWEExNmIyTngK",
      "endpoints": [
        "https://github.com/ga626/codex-provider-switcher/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "https://timestamp.digicert.com",
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false,
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "ga626",
    "shortDescription": "Manage local AI provider profiles safely.",
    "longDescription": "A Windows desktop tool for managing and switching local AI provider profiles with validation, backups, and safe recovery."
  }
}
