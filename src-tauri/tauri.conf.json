{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeX Provider Switcher",
  "version": "0.2.0-alpha",
  "identifier": "studio.codex.provider-switcher",
  "mainBinaryName": "codex-provider-switcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodeX Provider Switcher",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "CodeX Provider Switcher",
    "shortDescription": "Switch Codex provider profiles safely.",
    "longDescription": "A Windows-first desktop tool for managing and switching Codex provider profiles with validation, backups, and safe recovery."
  }
}
